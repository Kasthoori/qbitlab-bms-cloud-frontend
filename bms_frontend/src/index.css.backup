@import "tailwindcss";
@import "@fontsource-variable/inter";

.input {
  background: rgb(255 255 255 / 0.05);
  border: 1px solid rgb(255 255 255 / 0.1);
  border-radius: 0.75rem; /* rounded-xl */
  padding: 0.75rem 1rem; /* py-3 px-4 */
  color: #ffffff;
  outline: none;
  transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.input::placeholder {
  color: rgb(148 163 184); /* slate-400 */
}

.input:focus {
  border-color: rgb(96 165 250); /* blue-400 */
  box-shadow: 0 0 0 2px rgba(59,130,246,0.3); /* ring-2 + blue-500/30 */
}


:root {
    --font-sans: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
}

@layer base {
  body {
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
}

.glass-input {
  width: 100%;
  border-radius: 1rem;
  border: 1px solid rgb(255 255 255 / 0.1);
  background: rgb(2 6 23 / 0.55);
  padding: 0.75rem 0.9rem;
  color: rgb(241 245 249);
  outline: none;
  transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.glass-input::placeholder {
  color: rgb(100 116 139);
}

.glass-input:focus {
  border-color: rgb(103 232 249 / 0.75);
  box-shadow: 0 0 0 3px rgb(34 211 238 / 0.12);
  background: rgb(2 6 23 / 0.78);
}

.glass-input:disabled {
  cursor: not-allowed;
  opacity: 0.6;
}

@keyframes spin-slow {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.animate-spin-slow {
  animation: spin-slow 2s linear infinite;
}

.input-glass {
  width: 100%;
  border-radius: 1rem;
  border: 1px solid rgb(255 255 255 / 0.1);
  background: rgb(15 23 42 / 0.8);
  padding: 0.75rem 1rem;
  color: rgb(241 245 249);
  outline: none;
}

.input-glass::placeholder {
  color: rgb(100 116 139);
}

.input-glass:focus {
  box-shadow: 0 0 0 2px rgb(34 211 238 / 0.3);
}



