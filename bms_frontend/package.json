{
  "name": "bms_frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "build:debug": "tsc -b && vite build --debug",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test-run": "vitest run",
    "test-watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "debug": "vite --debug",
    "build-keycloak-theme": "cross-env KEYCLOAKIFY=1 keycloakify build",
    "storybook": "cross-env KEYCLOAKIFY=1 keycloakify storybook",
    "start-keycloak": "cross-env KEYCLOAKIFY=1 keycloakify start-keycloak",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@stomp/stompjs": "^7.2.1",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react-router-dom": "^5.3.3",
    "framer-motion": "^12.23.26",
    "keycloak-js": "^26.2.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.69.0",
    "react-router-dom": "6",
    "sockjs-client": "^1.6.1",
    "tailwindcss": "^4.1.17",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@keycloakify/keycloak-account-ui": "^260500.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/sockjs-client": "^1.5.4",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "5",
    "vitest": "^4.0.15"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
